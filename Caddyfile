# Caddy automatically obtains + renews Let's Encrypt certificates for these hosts.
# Websockets (socket.io) are proxied transparently — no extra config needed.
# DuckDNS resolves api.doptor-dev.duckdns.org to the same IP automatically.

doptor-dev.duckdns.org {
	encode gzip
	reverse_proxy web:3000
}

api.doptor-dev.duckdns.org {
	encode gzip
	reverse_proxy api:5000
}
