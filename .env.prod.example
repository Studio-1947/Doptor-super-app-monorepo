# ---------------------------------------------------------------------------
# Production environment for docker-compose.prod.yml
# Copy this to `.env` on the VPS and fill in real values. DO NOT commit `.env`.
# ---------------------------------------------------------------------------

# --- Database ---
POSTGRES_USER=doptor
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=doptor

# --- Backend / auth secrets (generate with: openssl rand -base64 48) ---
JWT_SECRET=CHANGE_ME_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_another_min_32_chars

# --- Public URLs (must match your Caddyfile domains) ---
# Frontend origin, used by the API for CORS + email links:
FRONTEND_URL=https://app.example.com
# API base URL baked into the frontend bundle at build time:
NEXT_PUBLIC_API_URL=https://api.example.com

# --- Email (optional; leave blank if unused) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@doptor.com
